# Rule to compile and run serial cpp file
# Run like this | make serial ARG=<filename> e.g. make serial ARG="data_100.txt"
serial:
	g++ TSP_Serial.cpp -o TSP_S
	./TSP_S $(ARG)

# Rule to compile and run parallel cpp file
# 4 threads used by default
# Run like this | make parallel ARG=<filename>  e.g. make parallel ARG="data_100.txt"
parallel:
	g++ -fopenmp TSP_Parallel.cpp -o TSP_P
	./TSP_P $(ARG) 4

# Rule to run serial python
# Run like this | make py ARG=<filename>  e.g. make py ARG="data_100.txt"
py:
	python3 TSP_Serial.py $(ARG)

# Rule to generate data files
# Run like this | make data ARG=<input size> e.g. make data ARG=2000 creates file data_2000.txt
data:
	g++ data_generator.cpp -o data_generator
	./data_generator $(ARG)

# Rule to run gui interface
gui:
	g++ TSP_Serial.cpp -o TSP_S
	g++ -fopenmp TSP_Parallel.cpp -o TSP_P
	python3 gui.py

# Rule to sort metrics file
sort_metrics:
	python3 Metrics_Sort.py

# Rule to automate running of files - input size 100 to 1000 - step size 1000
run_files:
	./run_files.sh

# Rule to create line graph - metrics file will be sorted first
graphs_line:
	make sort_metrics
	python3 graphs_line.py

# Rule to create scatter plot - metrics file will be sorted first
graphs_scatter:
	make sort_metrics
	python3 graphs_scatter.py

# Rule to create bar graph - metrics file will be sorted first
graphs_bar:
	make sort_metrics
	python3 graphs_bar.py

# Rule to remove the executable and object files created by g++ compilation
clean_executables:
	@rm -f TSP_S TSP_P data_generator *.o

# Rule to remove all txt files generated by data_generator 
clean_data:
	@rm -f d*.txt
